rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Resume files: only the owning user can read or write their resume ──
    match /resumes/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Avatars: publicly readable so <img> tags can load them straight from
    //    the bucket; only the owner may upload/overwrite their own avatar. ──
    match /avatars/{userId}.svg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Deny everything else ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
