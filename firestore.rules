rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. User Metadata Rules
    // Allows users to read/write only their own profile information
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "7Tojjo8l5PZIYctPmdwncf7PC133");
      
      // Public read for the admin's mapClusters aggregation only — used by the
      // landing-page hero map. Contains only aggregated city/lat/lng/count data.
      match /aggregations/mapClusters {
        allow read: if userId == "7Tojjo8l5PZIYctPmdwncf7PC133";
      }

      // 2. Nested Collections (feeds, companies, fetchRuns)
      // Standard rules for sub-collections inside a user document
      match /{allSubcollections=**} {
        // Admin's feeds, jobs, and companies are readable by everyone authenticated
        allow read: if request.auth != null && (userId == "7Tojjo8l5PZIYctPmdwncf7PC133" || request.auth.uid == userId);
        // Only the user themselves can write to their subcollections
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 3. Collection Group Rules for "jobs"
    // Allows Jobs.jsx to fetch jobs globally if the data matches the admin or the user
    match /{path=**}/jobs/{jobId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || resource.data.uid == "7Tojjo8l5PZIYctPmdwncf7PC133");
      // Write is handled by Cloud Functions or user-specific rules
    }
    
    match /interestedUsers/{docId} {
      allow create: if true;
      allow read: if request.auth != null && (request.auth.uid == "7Tojjo8l5PZIYctPmdwncf7PC133");
    }

    // Invite codes are unguessable 8-char bearer tokens. Anyone holding the
    // code can fetch the invite by ID (needed during /signup before the user
    // has authenticated). Listing the collection is admin-only so we don't
    // leak the full set of outstanding codes. Writes are restricted:
    //   - create: admin only
    //   - update: only to mark `used: true` on an unused, unexpired invite
    //   - delete: admin only
    // This makes the TTL and single-use guarantees enforceable server-side.
    match /invites/{inviteId} {
      allow get: if true;
      allow list: if request.auth != null
        && request.auth.uid == "7Tojjo8l5PZIYctPmdwncf7PC133";
      allow create, delete: if request.auth != null
        && request.auth.uid == "7Tojjo8l5PZIYctPmdwncf7PC133";
      allow update: if request.auth != null
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.usedBy == request.auth.uid
        && (resource.data.expiresAt == null || resource.data.expiresAt > request.time);
    }

    
    // Helper function to extract UID from path if needed
    function userIdFromPath(path) {
      return path[1]; // Returns 'uid' from /users/{uid}/...
    }
  }
}