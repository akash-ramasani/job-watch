{
  "manifest_version": 3,
  "name": "JobWatch Auto Apply",
  "version": "1.0.0",
  "description": "Automatically fill and submit job applications from JobWatch.",

  "permissions": ["storage", "tabs", "activeTab", "scripting", "downloads"],

  "host_permissions": [
    "*://*/*",
    "https://firestore.googleapis.com/*",
    "https://firebasestorage.googleapis.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://us-central1-greenhouse-jobs-scrapper.cloudfunctions.net/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://greenhouse-jobs-scrapper.web.app/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content/jobwatch-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobs.ashbyhq.com/*/application*"],
      "js": ["content/ashby.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "JobWatch Auto Apply",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
