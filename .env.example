# ── Firebase ─────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# ── App Check (reCAPTCHA Enterprise) ─────────────────────────────────────────
VITE_RECAPTCHA_SITE_KEY=

# ── Sentry (optional) ────────────────────────────────────────────────────────
# Sign up at https://sentry.io, create a React project, paste the DSN here
# (or set it as a Vercel env var) to enable error + session replay tracking.
VITE_SENTRY_DSN=

# ── PostHog (optional) ───────────────────────────────────────────────────────
# Sign up at https://posthog.com, copy the project API key.
# Host defaults to us.i.posthog.com; set to https://eu.i.posthog.com for EU.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
